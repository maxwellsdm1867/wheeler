"""Wheeler billing test — does the Agent SDK use your Max subscription?

Run this BEFORE building anything. It makes one tiny query and reports
what billing path was used.

Prerequisites:
    1. You have Claude Code CLI installed and logged in with Max subscription
    2. pip install claude-agent-sdk

Usage:
    python test_billing.py

What to check:
    1. Does it run at all? (If not: auth issue)
    2. Does total_cost_usd show 0.0 or None? (Max subscription = no per-token cost)
    3. Does total_cost_usd show a non-zero dollar amount? (API billing = costs money)
    4. Check your API console at https://console.anthropic.com/settings/billing
       before and after — did the balance change?

If it works on Max with no API charges, we use the Agent SDK directly.
If it charges API, we fall back to shelling out to `claude -p` instead.
"""

import asyncio
import json
import sys
import time


async def test_with_sdk():
    """Test using the Agent SDK (spawns Claude Code CLI internally)."""
    print("=" * 60)
    print("TEST 1: Agent SDK — query()")
    print("=" * 60)

    try:
        from claude_agent_sdk import query, ClaudeAgentOptions
    except ImportError:
        print("❌ claude-agent-sdk not installed.")
        print("   Run: pip install claude-agent-sdk")
        return None

    options = ClaudeAgentOptions(
        max_turns=1,  # Single turn, minimal cost
    )

    messages = []
    print("Sending: 'Reply with only the word PONG'...")
    start = time.time()

    try:
        async for msg in query(
            prompt="Reply with only the word PONG. Nothing else.",
            options=options,
        ):
            messages.append(msg)
    except Exception as e:
        print(f"❌ SDK query failed: {e}")
        print(f"   Error type: {type(e).__name__}")
        if "credit" in str(e).lower() or "billing" in str(e).lower():
            print("\n   ⚠️  This looks like a billing error.")
            print("   The SDK may be trying to use API billing instead of Max.")
            print("   Fallback: use `claude -p` CLI subprocess instead.")
        return None

    elapsed = time.time() - start

    # Parse the result message
    result_msg = None
    for msg in messages:
        # The SDK returns dataclass objects, check for ResultMessage
        msg_type = type(msg).__name__
        if msg_type == "ResultMessage":
            result_msg = msg
            break

    print(f"\nCompleted in {elapsed:.1f}s")
    print(f"Messages received: {len(messages)}")
    print(f"Message types: {[type(m).__name__ for m in messages]}")

    if result_msg:
        print(f"\n--- ResultMessage ---")
        print(f"  result:         {getattr(result_msg, 'result', 'N/A')}")
        print(f"  session_id:     {getattr(result_msg, 'session_id', 'N/A')}")
        print(f"  total_cost_usd: {getattr(result_msg, 'total_cost_usd', 'N/A')}")
        print(f"  num_turns:      {getattr(result_msg, 'num_turns', 'N/A')}")
        print(f"  duration_ms:    {getattr(result_msg, 'duration_ms', 'N/A')}")
        print(f"  is_error:       {getattr(result_msg, 'is_error', 'N/A')}")
        print(f"  usage:          {getattr(result_msg, 'usage', 'N/A')}")

        cost = getattr(result_msg, "total_cost_usd", None)
        if cost is None or cost == 0.0:
            print(f"\n  ✅ Cost is {cost} — likely running on Max subscription!")
            print(f"     Double-check: https://console.anthropic.com/settings/billing")
        else:
            print(f"\n  ⚠️  Cost is ${cost:.4f} — this is API billing!")
            print(f"     The SDK is NOT using your Max subscription.")
    else:
        print("\n⚠️  No ResultMessage found. Raw messages:")
        for i, msg in enumerate(messages):
            print(f"  [{i}] {type(msg).__name__}: {msg}")

    return result_msg


async def test_with_cli():
    """Test using raw CLI subprocess (guaranteed to use Max)."""
    print("\n" + "=" * 60)
    print("TEST 2: Raw CLI — claude -p (baseline)")
    print("=" * 60)

    import shutil

    claude_path = shutil.which("claude")
    if not claude_path:
        print("❌ Claude Code CLI not found in PATH.")
        print("   Install: npm install -g @anthropic-ai/claude-code")
        return None

    print(f"CLI path: {claude_path}")
    print("Sending: 'Reply with only the word PONG'...")
    start = time.time()

    proc = await asyncio.create_subprocess_exec(
        "claude", "-p", "Reply with only the word PONG. Nothing else.",
        "--output-format", "json",
        "--max-turns", "1",
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.PIPE,
    )

    stdout, stderr = await proc.communicate()
    elapsed = time.time() - start

    if proc.returncode != 0:
        print(f"❌ CLI exited with code {proc.returncode}")
        if stderr:
            err = stderr.decode()
            print(f"   stderr: {err[:500]}")
            if "credit" in err.lower():
                print("\n   ⚠️  Credit balance error — but this shouldn't happen with Max.")
        return None

    raw = stdout.decode().strip()
    print(f"\nCompleted in {elapsed:.1f}s")

    # Handle both JSON object and JSON array formats
    try:
        data = json.loads(raw)
    except json.JSONDecodeError:
        print(f"⚠️  Could not parse JSON. Raw output:\n{raw[:500]}")
        return None

    # If it's an array, find the result message
    if isinstance(data, list):
        for item in data:
            if isinstance(item, dict) and item.get("type") == "result":
                data = item
                break

    print(f"\n--- CLI JSON Response ---")
    print(f"  type:           {data.get('type', 'N/A')}")
    print(f"  subtype:        {data.get('subtype', 'N/A')}")
    print(f"  result:         {str(data.get('result', 'N/A'))[:80]}")
    print(f"  session_id:     {data.get('session_id', 'N/A')}")
    print(f"  total_cost_usd: {data.get('total_cost_usd', 'N/A')}")
    print(f"  num_turns:      {data.get('num_turns', 'N/A')}")
    print(f"  duration_ms:    {data.get('duration_ms', 'N/A')}")
    print(f"  is_error:       {data.get('is_error', 'N/A')}")

    cost = data.get("total_cost_usd")
    if cost is None or cost == 0.0:
        print(f"\n  ✅ Cost is {cost} — running on Max subscription!")
    else:
        print(f"\n  ⚠️  Cost is ${cost:.4f} — API billing detected!")

    return data


async def main():
    print("🔬 Wheeler Billing Test")
    print("Testing whether the Agent SDK uses your Max subscription.\n")
    print("BEFORE RUNNING: Note your current API credit balance at")
    print("  https://console.anthropic.com/settings/billing\n")

    sdk_result = await test_with_sdk()
    cli_result = await test_with_cli()

    # Summary
    print("\n" + "=" * 60)
    print("SUMMARY")
    print("=" * 60)

    sdk_cost = None
    cli_cost = None

    if sdk_result:
        sdk_cost = getattr(sdk_result, "total_cost_usd", None)
    if cli_result and isinstance(cli_result, dict):
        cli_cost = cli_result.get("total_cost_usd")

    print(f"  SDK cost:  {sdk_cost}")
    print(f"  CLI cost:  {cli_cost}")

    if sdk_cost is not None and sdk_cost > 0:
        print("\n  ⚠️  VERDICT: SDK uses API billing. Use CLI subprocess for Wheeler.")
    elif sdk_cost is None or sdk_cost == 0.0:
        print("\n  ✅ VERDICT: SDK appears to use Max subscription.")
        print("     → Safe to use Agent SDK with hooks + in-process MCP servers.")
        print("     → Verify: check API billing page hasn't changed.")
    else:
        print("\n  ❓ VERDICT: Inconclusive. Check billing page manually.")

    print(f"\nNOW CHECK: https://console.anthropic.com/settings/billing")
    print("If your credit balance is unchanged, Max is covering everything.\n")


if __name__ == "__main__":
    asyncio.run(main())