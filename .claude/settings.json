{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^(Read|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m wheeler.hooks.track_file_access"
          }
        ]
      },
      {
        "matcher": "^(Write|Edit)$",
        "hooks": [
          {
            "type": "command",
            "command": ".venv/bin/python -m wheeler.hooks.auto_register"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__wheeler_mutations__(ensure_artifact|add_plan|add_document|add_script|add_dataset|update_node)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m wheeler.hooks.read_before_mutate"
          }
        ]
      }
    ]
  }
}
