{
  "mcpServers": {
    "neo4j": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-neo4j-cypher@latest"
      ],
      "env": {
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_PASSWORD": "research-graph",
        "NEO4J_DATABASE": "neo4j"
      }
    },
    "wheeler": {
      "type": "stdio",
      "command": ".venv/bin/python",
      "args": [
        "-m",
        "wheeler.mcp_server"
      ]
    },
    "wheeler_core": {
      "type": "stdio",
      "command": ".venv/bin/python",
      "args": [
        "-m",
        "wheeler.mcp_core"
      ]
    },
    "wheeler_query": {
      "type": "stdio",
      "command": ".venv/bin/python",
      "args": [
        "-m",
        "wheeler.mcp_query"
      ]
    },
    "wheeler_mutations": {
      "type": "stdio",
      "command": ".venv/bin/python",
      "args": [
        "-m",
        "wheeler.mcp_mutations"
      ]
    },
    "wheeler_ops": {
      "type": "stdio",
      "command": ".venv/bin/python",
      "args": [
        "-m",
        "wheeler.mcp_ops"
      ]
    }
  }
}
