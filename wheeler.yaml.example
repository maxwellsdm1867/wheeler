neo4j:
  uri: bolt://localhost:7687
  username: neo4j
  password: research-graph
  database: neo4j

max_turns: 10
context_max_findings: 5
context_max_questions: 5
context_max_hypotheses: 3

# Project-specific data sources (optional)
# data_sources:
#   epicTreeGUI_root: "/path/to/epicTreeGUI"
#   data_dir: "/path/to/your/data"

models:
  chat: sonnet       # discussion, quick queries
  planning: opus     # scientific reasoning
  writing: opus      # drafting findings, revision
  execute: sonnet    # code gen, tool use, script execution

workspace:
  project_dir: "."
  scan_patterns: ["*.py", "*.m", "*.mat", "*.h5", "*.hdf5", "*.csv"]
  exclude_dirs: [".venv", "__pycache__", ".git", "node_modules", ".wheeler"]
