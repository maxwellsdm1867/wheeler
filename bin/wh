#!/usr/bin/env bash
# Wheeler CLI launcher — headless task runner and utilities.
#
# Interactive modes now run natively inside Claude Code via /wh:* slash commands.
# This script handles headless/independent work and development utilities.
#
# Install: sudo ln -sf ~/Documents/GitHub/wheeler/bin/wh /usr/local/bin/wh

set -euo pipefail

# ── Config ──────────────────────────────────────────────────────────
WHEELER_DIR="${WHEELER_DIR:-$HOME/Documents/GitHub/wheeler}"
CLAUDE_BIN="${CLAUDE_BIN:-claude}"

# Strip API key — Wheeler runs on Max subscription only
unset ANTHROPIC_API_KEY 2>/dev/null || true

# ── Colors ──────────────────────────────────────────────────────────
AMBER='\033[38;2;212;160;100m'
DIM='\033[38;2;85;85;85m'
BLUE='\033[38;2;96;165;250m'
PURPLE='\033[38;2;167;139;250m'
GREEN='\033[38;2;52;211;153m'
ORANGE='\033[38;2;249;115;22m'
RED='\033[38;2;239;68;68m'
BOLD='\033[1m'
RESET='\033[0m'

# ── Helpers ─────────────────────────────────────────────────────────
banner() {
    local mode="$1" model="$2" color="$3"
    echo ""
    echo -e "  ${AMBER}${BOLD}Wheeler${RESET} ${DIM}co-scientist${RESET}"
    echo -e "  ${color}${BOLD}${mode}${RESET} ${DIM}→ ${model}${RESET}"
    echo -e "  ${DIM}${WHEELER_DIR}${RESET}"
    echo ""
}

die() {
    echo -e "  ${RED}error:${RESET} $1" >&2
    exit 1
}

usage() {
    echo ""
    echo -e "  ${AMBER}${BOLD}Wheeler${RESET} ${DIM}— a thinking partner for scientists${RESET}"
    echo ""
    echo -e "  ${BOLD}Interactive (inside Claude Code)${RESET}"
    echo -e "    ${DIM}cd ~/wheeler && claude${RESET}"
    echo -e "    ${AMBER}/wh:discuss${RESET}           ${DIM}Sharpen the question before planning${RESET}"
    echo -e "    ${AMBER}/wh:plan${RESET}              ${DIM}Structured investigation plan${RESET}"
    echo -e "    ${AMBER}/wh:chat${RESET}              ${DIM}Quick discussion${RESET}"
    echo -e "    ${AMBER}/wh:execute${RESET}           ${DIM}Run analyses with provenance${RESET}"
    echo -e "    ${AMBER}/wh:write${RESET}             ${DIM}Draft text with strict citations${RESET}"
    echo -e "    ${AMBER}/wh:handoff${RESET}           ${DIM}Propose tasks for independent execution${RESET}"
    echo -e "    ${AMBER}/wh:reconvene${RESET}         ${DIM}Review independent results${RESET}"
    echo -e "    ${AMBER}/wh:ingest${RESET}            ${DIM}Bootstrap graph from data${RESET}"
    echo -e "    ${AMBER}/wh:status${RESET}            ${DIM}Progress check + routing${RESET}"
    echo -e "    ${AMBER}/wh:pause${RESET}             ${DIM}Capture state for later${RESET}"
    echo -e "    ${AMBER}/wh:resume${RESET}            ${DIM}Restore context from previous session${RESET}"
    echo ""
    echo -e "  ${BOLD}Independent (headless, logged to .logs/)${RESET}"
    echo -e "    ${AMBER}wh queue${RESET} \"prompt\"    ${DIM}Queue a task (sonnet, 10 turns)${RESET}"
    echo -e "    ${AMBER}wh quick${RESET} \"prompt\"    ${DIM}Fast one-shot (haiku, 3 turns)${RESET}"
    echo -e "    ${AMBER}wh status${RESET}            ${DIM}Graph status (haiku, 2 turns)${RESET}"
    echo -e "    ${AMBER}wh dream${RESET}             ${DIM}Consolidate graph: promote, link, prune (sonnet, 15 turns)${RESET}"
    echo ""
    echo -e "  ${BOLD}Development${RESET}"
    echo -e "    ${AMBER}wh hooks install${RESET}     ${DIM}Install git pre-commit/pre-push hooks${RESET}"
    echo -e "    ${AMBER}wh hooks test${RESET}        ${DIM}Run all checks without committing${RESET}"
    echo ""
    echo -e "  ${BOLD}Options${RESET}"
    echo -e "    ${DIM}WHEELER_MODEL=sonnet wh queue \"...\"${RESET}  ${DIM}Override model${RESET}"
    echo -e "    ${DIM}WHEELER_DIR=/path/to/project${RESET}       ${DIM}Override project dir${RESET}"
    echo ""
}

# Run headless with a command file as system context + user prompt
# If log=true, tee output to .logs/<timestamp>.json
run_headless() {
    local cmd_file="$1" prompt="$2" model="$3" color="$4" mode_name="$5" max_turns="$6" fmt="$7" log="${8:-false}"
    shift 7; shift 2>/dev/null || true
    MODEL="${WHEELER_MODEL:-$model}"
    banner "$mode_name" "$MODEL" "$color"

    # Build command array
    local -a cmd=("$CLAUDE_BIN" -p "$prompt" --model "$MODEL" --output-format "$fmt" --max-turns "$max_turns")
    if [[ -f "$WHEELER_DIR/.claude/commands/wh/${cmd_file}.md" ]]; then
        cmd+=(--system-prompt "$(cat "$WHEELER_DIR/.claude/commands/wh/${cmd_file}.md")")
    fi
    cmd+=("$@")

    if [[ "$log" == "true" ]]; then
        mkdir -p "$WHEELER_DIR/.logs"
        local logfile="$WHEELER_DIR/.logs/$(date +%Y%m%d-%H%M%S)-${mode_name}.json"
        echo -e "  ${DIM}logging to: .logs/$(basename "$logfile")${RESET}"
        echo ""
        local t_start
        t_start=$(date +%s)
        "${cmd[@]}" | tee "$logfile"
        local t_end
        t_end=$(date +%s)
        local duration=$(( t_end - t_start ))
        # Structured task log: wraps raw output + citation validation + checkpoint detection
        echo ""
        "$WHEELER_DIR/.venv/bin/python" -m wheeler.task_log "$logfile" "$prompt" "$MODEL" "$duration" 2>/dev/null || true
    else
        exec "${cmd[@]}"
    fi
}

# ── Validate ────────────────────────────────────────────────────────
command -v "$CLAUDE_BIN" >/dev/null 2>&1 || die "claude CLI not found. Install: npm install -g @anthropic-ai/claude-code"
[[ -d "$WHEELER_DIR" ]] || die "Wheeler project not found at $WHEELER_DIR"
[[ -f "$WHEELER_DIR/CLAUDE.md" ]] || die "No CLAUDE.md in $WHEELER_DIR — is this the right project?"

# ── Pre-flight checks ─────────────────────────────────────────────
# Quick Neo4j connectivity check — if it's down, MCP servers will hang
if ! nc -z localhost 7687 2>/dev/null; then
    echo -e "  ${AMBER}!${RESET} ${DIM}Neo4j not reachable on localhost:7687 — graph tools may be slow${RESET}"
fi

# ── Navigate ────────────────────────────────────────────────────────
cd "$WHEELER_DIR"

# ── Parse subcommand ────────────────────────────────────────────────
SUBCMD="${1:-help}"
shift 2>/dev/null || true

case "$SUBCMD" in

    # ── Independent / headless commands ─────────────────────────────
    queue|q)
        PROMPT="${1:?Usage: wh queue \"prompt here\"}"
        shift
        run_headless "queue" "$PROMPT" "sonnet" "$DIM" "queue" "10" "json" "true" "$@"
        ;;

    quick)
        PROMPT="${1:?Usage: wh quick \"prompt here\"}"
        shift
        run_headless "queue" "$PROMPT" "haiku" "$DIM" "quick" "3" "json" "true" "$@"
        ;;

    status|st)
        run_headless "status" "Run the status check described in your system prompt." "haiku" "$DIM" "status" "2" "text" "$@"
        ;;

    dream)
        run_headless "dream" "Run the dream consolidation described in your system prompt." "sonnet" "$PURPLE" "dream" "15" "json" "true" "$@"
        ;;

    # ── Hooks ─────────────────────────────────────────────────────
    hooks)
        HOOKS_CMD="${1:-}"
        shift 2>/dev/null || true
        case "$HOOKS_CMD" in
            install)
                if [[ ! -d "$WHEELER_DIR/.git" ]]; then
                    die "Not a git repository"
                fi
                cp "$WHEELER_DIR/.githooks/pre-commit" "$WHEELER_DIR/.git/hooks/pre-commit"
                cp "$WHEELER_DIR/.githooks/pre-push" "$WHEELER_DIR/.git/hooks/pre-push"
                chmod +x "$WHEELER_DIR/.git/hooks/pre-commit" "$WHEELER_DIR/.git/hooks/pre-push"
                echo -e "  ${GREEN}✓${RESET} Hooks installed to .git/hooks/"
                ;;
            test)
                echo -e "  ${AMBER}${BOLD}Running all pre-commit checks...${RESET}"
                echo ""
                bash "$WHEELER_DIR/.githooks/pre-commit"
                ;;
            *)
                echo -e "  ${BOLD}Usage:${RESET}"
                echo -e "    ${AMBER}wh hooks install${RESET}   ${DIM}Install git hooks${RESET}"
                echo -e "    ${AMBER}wh hooks test${RESET}      ${DIM}Run all checks manually${RESET}"
                ;;
        esac
        exit 0
        ;;

    # ── Meta ────────────────────────────────────────────────────────
    help|-h|--help)
        usage
        exit 0
        ;;

    *)
        echo -e "  ${RED}Unknown command:${RESET} $SUBCMD"
        usage
        exit 1
        ;;
esac
